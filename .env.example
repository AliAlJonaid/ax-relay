# Copy to .env and fill in your own values. Never commit .env.

# --- Provider API keys ---
GEMINI_API_KEY=          # Google AI Studio (when AGENT_PROVIDER=google)
OPENROUTER_API_KEY=      # OpenRouter (default cloud provider)
ZENMUX_API_KEY=          # ZenMux free-tier models
GROQ_API_KEY=            # Groq inference
CEREBRAS_API_KEY=        # Cerebras inference

# --- Model routing ---
# Comma-separated failover chain: provider:model_id,provider:model_id,...
AGENT_PROVIDER_CHAIN=
AGENT_PROVIDER=          # Single provider override (openrouter | groq | cerebras | google | local | custom)
AGENT_MODEL=             # Model id for the chosen provider

# --- Generation ---
AGENT_TEMPERATURE=
AGENT_MAX_TOKENS=
AGENT_MIN_CALL_INTERVAL_S=   # Minimum seconds between API calls (rate-limit hygiene)
MAX_STEPS=                     # Max agent loop steps per task
AGENT_SCREENSHOTS=             # 1 = capture screenshots for awareness / Telegram; 0 = off

# --- Telegram remote control ---
TELEGRAM_BOT_TOKEN=            # From @BotFather
TELEGRAM_ALLOWED_CHAT_ID=      # Required for control commands; only /whoami works while unset
